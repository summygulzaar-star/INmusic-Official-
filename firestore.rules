rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitive Definition ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isVerifiedUser() { return isSignedIn() && isEmailVerified(); }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens never contain custom claims in this environment, use DB lookup
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == "musicdistributionindia.in@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'artist') in ['admin', 'content_manager', 'finance_admin', 'support'])
      );
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "musicdistributionindia.in@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Validation Blueprints ---
    function isString(val) { return val is string; }
    function isTimestamp(val) { return val is timestamp; }
    function isDate(val) { return isString(val) || isTimestamp(val); }

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role in ['artist', 'admin', 'content_manager', 'finance_admin', 'support'] &&
             data.walletBalance is number &&
             data.status in ['active', 'suspended'] &&
             isDate(data.createdAt) &&
             data.keys().hasAll(['email', 'displayName', 'role', 'walletBalance', 'status', 'createdAt']) &&
             data.keys().size() >= 6;
    }

    function isValidRelease(data) {
      return data.userId is string &&
             data.title is string && data.title.size() <= 256 &&
             data.artist is string && data.artist.size() <= 128 &&
             data.status in ['pending', 'approved', 'in_progress', 'live', 'action_required', 'rejected', 'takedown_requested', 'completed'] &&
             isDate(data.createdAt) &&
             data.keys().hasAll(['userId', 'title', 'artist', 'status', 'createdAt']);
    }

    function isValidWithdrawal(data) {
      return data.userId is string &&
             data.amount is number && data.amount >= 500 &&
             data.method in ['UPI', 'Bank'] &&
             data.status in ['pending', 'completed', 'rejected'] &&
             isDate(data.createdAt) &&
             data.keys().hasAll(['userId', 'amount', 'method', 'status', 'createdAt']);
    }

    function isValidNotification(data) {
      return data.title is string && data.title.size() <= 128 &&
             data.message is string && data.message.size() <= 512 &&
             isDate(data.createdAt) &&
             data.keys().hasAll(['title', 'message', 'createdAt']);
    }

    function isValidSupportTicket(data) {
      return data.userId is string &&
             data.subject is string && data.subject.size() <= 256 &&
             data.message is string && data.message.size() <= 2048 &&
             data.status in ['pending', 'resolved'] &&
             isDate(data.createdAt) &&
             data.keys().hasAll(['userId', 'subject', 'message', 'status', 'createdAt']);
    }

    function isValidUserRequest(data) {
      return data.ticketId is string &&
             data.userId is string &&
             data.type is string &&
             data.priority in ['normal', 'high', 'urgent'] &&
             data.status in ['pending', 'in_review', 'approved', 'rejected', 'completed'] &&
             isDate(data.createdAt) &&
             data.keys().hasAll(['ticketId', 'userId', 'type', 'status', 'priority', 'createdAt']);
    }

    // --- Collection Rules ---

    // Broadcast Notifications
    match /system_notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidNotification(incoming());
    }

    // User Notifications
    match /user_notifications/{notificationId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerifiedUser() && isValidSupportTicket(incoming()) && (incoming().userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // User Requests (Centralized)
    match /user_requests/{requestId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidUserRequest(incoming()) && incoming().status == 'pending';
      allow update: if (isAdmin() || (
        isOwner(existing().userId) && 
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['data', 'priority', 'type']) &&
        existing().status == 'pending'
      ));
    }

    // Request Logs
    match /request_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin();
    }

    // System Config & Status
    match /system/{id} {
      allow read: if isSignedIn() || (id == 'status');
      allow write: if isAdmin();
    }

    // Users: Highly sensitive PII
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && (incoming().walletBalance == 0);
      allow update: if (
        (isOwner(userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phone', 'photoURL']) &&
         incoming().email == existing().email &&
         incoming().role == existing().role &&
         incoming().walletBalance == existing().walletBalance
        ) || isAdmin()
      );
    }

    // Artists & Labels
    match /artists/{artistId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isOwner(incoming().userId);
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    match /labels/{labelId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isOwner(incoming().userId);
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    // Releases
    match /releases/{releaseId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isVerifiedUser() && isOwner(incoming().userId) && isValidRelease(incoming()) && incoming().status == 'pending';
      
      allow update: if (isAdmin() || (
        isOwner(existing().userId) && 
        incoming().userId == existing().userId &&
        isValidRelease(incoming()) &&
        (
          // Action: User correction
          (existing().status in ['pending', 'action_required'] && 
           incoming().status == 'pending' &&
           incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'singerName', 'instagramId', 'lyricist', 'lyrics', 'composer', 'producer', 'copyright', 'publisher', 'language', 'primaryGenre', 'secondaryGenre', 'releaseDate', 'releaseTime', 'label', 'audioUrl', 'coverUrl', 'selectedPlatforms', 'metadata'])) ||
          
          // Action: Takedown
          (existing().status == 'live' &&
           incoming().status == 'takedown_requested' &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        )
      ));
      
      allow delete: if isAdmin();
    }

    // Withdrawals
    match /withdrawals/{withdrawalId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isVerifiedUser() && isOwner(incoming().userId) && isValidWithdrawal(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // OAC & Content ID
    match /oac_requests/{requestId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isVerifiedUser() && isOwner(incoming().userId) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    match /content_id_requests/{requestId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isVerifiedUser() && isOwner(incoming().userId) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    // Royalty Reports
    match /royalty_reports/{reportId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Admin Logs
    match /admin_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
    }

    // Static Admin UIDs
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
